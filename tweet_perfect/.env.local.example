# ===================================
# NextAuth Configuration
# ===================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# Admin Credentials (CHANGE THESE IN PRODUCTION!)
NEXTAUTH_ADMIN_USERNAME=admin
NEXTAUTH_ADMIN_PASSWORD=your-secure-password

# ===================================
# OpenAI Configuration
# ===================================
# Get your key from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-...

# Optional: Organization ID from https://platform.openai.com/account/org-settings
# OPENAI_ORGANISATION=org-...

# ===================================
# Database Configuration
# ===================================
# Only needed if using Prisma with database backend
# DATABASE_URL=postgresql://user:password@localhost:5432/tweetperfect

# ===================================
# Public Configuration (sent to client)
# ===================================
# NEXT_PUBLIC_API_URL=http://localhost:3000
