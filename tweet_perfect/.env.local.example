# Database Configuration
# For development, SQLite is used (creates a local database file)
# For production, you can migrate to PostgreSQL
DATABASE_URL="file:./prisma/dev.db"

# OpenAI Configuration
# Get these from https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk_your_api_key_here
OPENAI_ORGANISATION=org-your-org-id_here

# NextAuth Configuration
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_generated_secret_here

# GitHub OAuth Configuration
# Create an app at: https://github.com/settings/developers
GITHUB_ID=your_github_app_id
GITHUB_SECRET=your_github_app_secret

# Google OAuth Configuration (Optional)
# Create a project at: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# For Vercel Deployment
# Add these same variables in Vercel project settings
# For production database, consider using Vercel Postgres or external PostgreSQL service
